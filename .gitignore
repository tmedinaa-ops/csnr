# =============================================================================
# CSNR .gitignore
# Track the model definition (text: .py .i .sh .md, source data, deliverables).
# Never track generated inputs, run outputs, meshes, data, or build artifacts:
# they are large, machine-specific, and reproducible, and they cause sync drift.
# =============================================================================

# ---- OpenMC inputs generated by the python builders (regenerate per machine) --
model.xml
geometry.xml
materials.xml
settings.xml
tallies.xml
plots.xml

# ---- OpenMC run outputs ------------------------------------------------------
statepoint.*.h5
summary.h5
tallies.out
*.ppm

# ---- MOOSE / Cardinal generated meshes and Exodus outputs --------------------
*.e
*.exo

# ---- Cardinal / MOOSE result CSVs (sources like SNAP-10A_Validation_Targets.csv
#      stay tracked; these are run outputs) -----------------------------------
**/solid_3d.csv
**/thm_nak.csv
**/mvp_solid.csv
**/mvp_nak.csv
**/axial_power.csv

# ---- logs --------------------------------------------------------------------
*.log

# ---- Cardinal JIT cache and compiled objects ---------------------------------
.jitcache/
*.so

# ---- transfer bundles (rebuilt on demand) ------------------------------------
*.zip

# ---- python / editor / OS cruft ----------------------------------------------
__pycache__/
*.pyc
*.swp
.DS_Store

# Note: nuclear data (ENDF/B-VIII.0) and cardinal-opt are NOT in this repo by
# design. They live per-machine; their paths go in the shell env, not in files.
